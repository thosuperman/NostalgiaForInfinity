{
  "$schema": "https://schema.freqtrade.io/schema.json",
  
  "strategy": "NostalgiaForInfinityX6",
  "max_open_trades": 4,
  "stake_currency": "USDT",
  "stake_amount": 100,
  "tradable_balance_ratio": 0.6,
  "fiat_display_currency": "USD",
  "dry_run": false,
  "dry_run_wallet": 500,
  "cancel_open_orders_on_exit": false,
  
  "trading_mode": "futures",
  "margin_mode": "isolated",
  "futures_mode_leverage": 3,
  "futures_mode_leverage_rebuy_mode": 3,
  "futures_mode_leverage_grind_mode": 3,
  
  "position_adjustment_enable": true,
  "max_entry_position_adjustment": 2,
  
  "unfilledtimeout": {
    "entry": 5,
    "exit": 5,
    "exit_timeout_count": 0,
    "unit": "minutes"
  },
  
  "order_types": {
    "entry": "limit",
    "exit": "limit",
    "emergency_exit": "market",
    "force_entry": "limit",
    "force_exit": "market",
    "stoploss": "market",
    "stoploss_on_exchange": true,
    "stoploss_on_exchange_interval": 30,
    "stoploss_on_exchange_limit_ratio": 0.99
  },
  
  "entry_pricing": {
    "price_side": "same",
    "use_order_book": true,
    "order_book_top": 3,
    "price_last_balance": 0.0,
    "check_depth_of_market": {
      "enabled": true,
      "bids_to_ask_delta": 1
    }
  },
  
  "exit_pricing": {
    "price_side": "same",
    "use_order_book": true,
    "order_book_top": 1,
    "price_last_balance": 0.0
  },
  
  "protections": [
    {
      "method": "StoplossGuard",
      "lookback_period_candles": 60,
      "trade_limit": 3,
      "stop_duration_candles": 15,
      "only_per_pair": false
    },
    {
      "method": "MaxDrawdown",
      "lookback_period_candles": 200,
      "trade_limit": 15,
      "stop_duration_candles": 30,
      "max_allowed_drawdown": 0.15
    },
    {
      "method": "LowProfitPairs",
      "lookback_period_candles": 300,
      "trade_limit": 8,
      "stop_duration_candles": 45,
      "required_profit": 0.015
    }
  ],
  
  "pair_whitelist": [
    "BTC/USDT:USDT",
    "ETH/USDT:USDT",
    "BNB/USDT:USDT",
    "SOL/USDT:USDT",
    "XRP/USDT:USDT",
    "ADA/USDT:USDT",
    "DOGE/USDT:USDT",
    "LINK/USDT:USDT",
    "AVAX/USDT:USDT",
    "DOT/USDT:USDT",
    "LTC/USDT:USDT",
    "ATOM/USDT:USDT",
    "NEAR/USDT:USDT",
    "APT/USDT:USDT",
    "OP/USDT:USDT",
    "ARB/USDT:USDT",
    "AAVE/USDT:USDT",
    "INJ/USDT:USDT",
    "LDO/USDT:USDT",
    "PENDLE/USDT:USDT",
    "TON/USDT:USDT",
    "SUI/USDT:USDT",
    "TAO/USDT:USDT",
    "WLD/USDT:USDT",
    "FET/USDT:USDT",
    "ONDO/USDT:USDT",
    "ENA/USDT:USDT",
    "WIF/USDT:USDT",
    "BOME/USDT:USDT",
    "POPCAT/USDT:USDT",
    "NOT/USDT:USDT",
    "DOGS/USDT:USDT",
    "FIL/USDT:USDT",
    "TRX/USDT:USDT",
    "ETC/USDT:USDT",
    "ALGO/USDT:USDT",
    "SAND/USDT:USDT",
    "MOVE/USDT:USDT"
  ],
  
  "pair_blacklist": [
    "*BULL/USDT:USDT",
    "*BEAR/USDT:USDT",
    "*UP/USDT:USDT",
    "*DOWN/USDT:USDT",
    "FARTCOIN/USDT:USDT",
    "S/USDT:USDT",
    "TRUMP/USDT:USDT"
  ],
  
  "add_config_files": [
    "../configs/exampleconfig_secret.json"
  ]
}
